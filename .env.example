# GEMINI_API_KEY: Server-side Gemini key. Never expose this in frontend builds.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY: Optional public browser key. Leave empty unless you
# intentionally want browser-side Gemini calls.
VITE_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ImageKit Configuration
VITE_IMAGEKIT_PUBLIC_KEY=
VITE_IMAGEKIT_URL_ENDPOINT=
# IMAGEKIT_PRIVATE_KEY= (Server-side only)

# Google OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_API_KEY=
